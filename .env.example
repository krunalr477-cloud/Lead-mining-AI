# ============================================================================
# LeadMine AI — environment configuration
# Copy to .env and fill in. NEVER commit .env.
# ============================================================================

# --- Core ---
DATABASE_URL=postgresql+psycopg://leadmine:leadmine@127.0.0.1:5432/leadmine
REDIS_URL=redis://127.0.0.1:6379/0
JWT_SECRET=                                  # generate: openssl rand -hex 32
APP_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
ENVIRONMENT=development                      # development | production
DEMO_MODE=true                               # true forces ALL adapters to mock

# --- Google (see docs/GOOGLE_SETUP.md for the console runbook) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback
GOOGLE_MAPS_API_KEY=                         # SERVER key: Places API (New) + Geocoding only
GOOGLE_SHEETS_SCOPES=https://www.googleapis.com/auth/spreadsheets
GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.send https://www.googleapis.com/auth/gmail.readonly

# --- Providers ---
ROCKETREACH_API_KEY=
MILLIONVERIFIER_API_KEY=
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
SERP_PROVIDER=serpapi                        # serpapi | serper | mock
SERP_API_KEY=

# --- Object storage (optional; exports fall back to local disk when empty) ---
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# --- Security & policy ---
ENCRYPTION_KEY=                              # generate: uv run python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DEFAULT_SEND_LIMIT_PER_HOUR=100
DEFAULT_SEND_LIMIT_PER_DAY=300
BOUNCE_POLL_INTERVAL_MINUTES=30
VALIDATION_LLM_THRESHOLD=0.55
ENABLE_FACEBOOK_SIGNALS=false
ENABLE_LINKEDIN_CONNECTOR=false
ENABLE_COMPLIANCE_GATED_SOURCES=false

# --- Adapter mode overrides (optional) ---
ADAPTER_MODE=auto                            # auto | real | mock
# Per-source override, e.g.:
# SOURCE_GOOGLE_MAPS_MODE=real

# --- Crawler ---
CRAWLER_MAX_PAGES_PER_DOMAIN=8
CRAWLER_PER_DOMAIN_DELAY_SECONDS=2

# --- Sheets sync ---
SHEETS_WRITES_PER_MINUTE=50

# --- Microsoft (Outlook / Entra ID) sign-in ---
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=common
MICROSOFT_REDIRECT_URI=http://localhost:8000/api/v1/auth/microsoft/callback
